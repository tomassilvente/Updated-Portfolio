---
import { content } from "../i18n/content";
const en = content.en.footer;
const es = content.es.footer;
---

<footer class="border-t border-zinc-200 dark:border-zinc-800 py-8">
  <div
    class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-zinc-400 dark:text-zinc-500"
  >
    <p class="font-mono">
      <span class="lang-en">{en.built}</span>
      <span class="lang-es">{es.built}</span>
    </p>

    <div class="flex items-center gap-4">
      <span class="font-mono">
        <span class="lang-en">Built with</span>
        <span class="lang-es">Hecho con</span>
        {" "}
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
        >
          Astro
        </a>
        {" "}+{" "}
        <a
          href="https://tailwindcss.com"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-zinc-700 dark:hover:text-zinc-300 transition-colors"
        >
          Tailwind
        </a>
      </span>
    </div>
  </div>
</footer>
