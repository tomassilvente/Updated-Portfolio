---
import { content } from "../i18n/content";
const en = content.en.experience;
const es = content.es.experience;
---

<section id="experience" class="py-24 border-t border-zinc-200 dark:border-zinc-800">
  <div class="max-w-5xl mx-auto px-6">
    <div class="reveal mb-12">
      <p class="font-mono text-xs text-indigo-600 dark:text-indigo-400 mb-3 tracking-wider uppercase">
        02 —
      </p>
      <h2 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-50">
        <span class="lang-en">{en.title}</span>
        <span class="lang-es">{es.title}</span>
      </h2>
    </div>

    <div class="space-y-0">
      {
        en.jobs.map((job, i) => (
          <div class="reveal group relative grid md:grid-cols-[200px_1fr] gap-6 md:gap-10 py-8 border-b border-zinc-200 dark:border-zinc-800 last:border-0">
            <!-- Period + Location (left column) -->
            <div class="flex md:flex-col gap-2 md:gap-1">
              <p class="font-mono text-xs text-zinc-400 dark:text-zinc-500 whitespace-nowrap">
                <span class="lang-en">{job.period}</span>
                <span class="lang-es">{es.jobs[i].period}</span>
              </p>
              <p class="font-mono text-xs text-zinc-400 dark:text-zinc-500">
                <span class="lang-en">{job.location}</span>
                <span class="lang-es">{es.jobs[i].location}</span>
              </p>
            </div>

            <!-- Content (right column) -->
            <div>
              <div class="flex flex-wrap items-baseline gap-2 mb-3">
                <h3 class="text-base font-semibold text-zinc-900 dark:text-zinc-100">
                  <span class="lang-en">{job.role}</span>
                  <span class="lang-es">{es.jobs[i].role}</span>
                </h3>
                <span class="text-zinc-400 dark:text-zinc-500 text-sm">@</span>
                <span class="text-indigo-600 dark:text-indigo-400 text-sm font-medium">
                  {job.company}
                </span>
              </div>

              <ul class="space-y-2">
                {job.bullets.map((bullet, j) => (
                  <li class="flex items-start gap-3 text-sm text-zinc-600 dark:text-zinc-300 leading-relaxed">
                    <span class="text-indigo-500 dark:text-indigo-400 mt-1.5 flex-shrink-0">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="10"
                        height="10"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                      >
                        <circle cx="12" cy="12" r="4" />
                      </svg>
                    </span>
                    <span>
                      <span class="lang-en">{bullet}</span>
                      <span class="lang-es">{es.jobs[i].bullets[j]}</span>
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
