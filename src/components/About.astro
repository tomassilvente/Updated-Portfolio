---
import { content } from "../i18n/content";
const en = content.en.about;
const es = content.es.about;
---

<section id="about" class="py-24 border-t border-zinc-200 dark:border-zinc-800">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Photo -->
      <div class="reveal order-2 md:order-1">
        <div class="relative">
          <div
            class="absolute -inset-4 bg-indigo-600/5 dark:bg-indigo-400/5 rounded-2xl"
          >
          </div>
          <img
            src="/photo.jpg"
            alt="Tomás Silvente"
            class="relative w-full max-w-sm mx-auto md:max-w-none aspect-[4/5] object-cover rounded-xl grayscale hover:grayscale-0 transition-all duration-500"
            loading="lazy"
          />
        </div>
      </div>

      <!-- Text -->
      <div class="reveal order-1 md:order-2">
        <p class="font-mono text-xs text-indigo-600 dark:text-indigo-400 mb-3 tracking-wider uppercase">
          <span class="lang-en">01 —</span>
          <span class="lang-es">01 —</span>
        </p>
        <h2 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-50 mb-6">
          <span class="lang-en">{en.title}</span>
          <span class="lang-es">{es.title}</span>
        </h2>

        <div class="space-y-4 text-zinc-600 dark:text-zinc-300 leading-relaxed">
          <div class="lang-en">
            {en.bio.map((p) => <p>{p}</p>)}
          </div>
          <div class="lang-es">
            {es.bio.map((p) => <p>{p}</p>)}
          </div>
        </div>

        <!-- Education mini-block -->
        <div class="mt-8 pt-6 border-t border-zinc-200 dark:border-zinc-800 space-y-2">
          <p class="text-xs font-mono text-zinc-400 dark:text-zinc-500 mb-3 uppercase tracking-wider">
            <span class="lang-en">Education</span>
            <span class="lang-es">Educación</span>
          </p>
          <div class="flex items-start gap-3">
            <div class="w-1 h-1 rounded-full bg-indigo-500 mt-2 flex-shrink-0"></div>
            <div>
              <p class="text-sm font-medium text-zinc-800 dark:text-zinc-200">
                <span class="lang-en">Systems Analyst</span>
                <span class="lang-es">Analista de Sistemas</span>
              </p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400">Instituto Superior Técnico 190 · 2020–2025</p>
            </div>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-1 h-1 rounded-full bg-indigo-500 mt-2 flex-shrink-0"></div>
            <div>
              <p class="text-sm font-medium text-zinc-800 dark:text-zinc-200">
                <span class="lang-en">Network Technician</span>
                <span class="lang-es">Técnico en Redes</span>
              </p>
              <p class="text-xs text-zinc-500 dark:text-zinc-400">TECLAB · 2020–2021</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
