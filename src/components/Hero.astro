---
import { content } from "../i18n/content";
const en = content.en.hero;
const es = content.es.hero;
---

<section
  class="min-h-screen flex items-center pt-16"
  aria-label="Hero"
>
  <div class="max-w-5xl mx-auto px-6 py-24 w-full">
    <p class="font-mono text-sm text-indigo-600 dark:text-indigo-400 mb-4 anim-1">
      <span class="lang-en">{en.greeting}</span>
      <span class="lang-es">{es.greeting}</span>
    </p>

    <h1
      class="text-5xl sm:text-6xl md:text-7xl font-semibold tracking-tight text-zinc-900 dark:text-zinc-50 leading-[1.05] mb-5 anim-2"
    >
      {en.name}
    </h1>

    <p
      class="font-mono text-base sm:text-lg text-zinc-500 dark:text-zinc-400 mb-8 anim-3"
    >
      <span class="lang-en">{en.role}</span>
      <span class="lang-es">{es.role}</span>
    </p>

    <div class="w-12 h-px bg-indigo-600 dark:bg-indigo-400 mb-8 anim-3"></div>

    <p
      class="text-lg sm:text-xl text-zinc-600 dark:text-zinc-300 max-w-xl leading-relaxed mb-10 anim-4"
    >
      <span class="lang-en">{en.tagline}</span>
      <span class="lang-es">{es.tagline}</span>
    </p>

    <!-- Actions -->
    <div class="flex flex-wrap items-center gap-4 mb-14 anim-5">
      <a
        href="#projects"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-indigo-600 dark:bg-indigo-500 text-white text-sm font-medium hover:bg-indigo-700 dark:hover:bg-indigo-400 transition-colors"
      >
        <span class="lang-en">{en.cta}</span>
        <span class="lang-es">{es.cta}</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>

      <a
        href="#contact"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-zinc-300 dark:border-zinc-700 text-zinc-700 dark:text-zinc-300 text-sm font-medium hover:border-zinc-900 dark:hover:border-zinc-100 hover:text-zinc-900 dark:hover:text-zinc-100 transition-all"
      >
        <span class="lang-en">Get in touch</span>
        <span class="lang-es">Contacto</span>
      </a>
    </div>

    <!-- Social links + location -->
    <div class="flex flex-wrap items-center gap-5 anim-6">
      <a
        href="https://github.com/tomassilvente"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
        aria-label="GitHub"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
        GitHub
      </a>

      <a
        href="https://www.linkedin.com/in/tomás-silvente-a4b1951b2/"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link"
        aria-label="LinkedIn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="currentColor"
        >
          <path
            d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
          ></path>
        </svg>
        LinkedIn
      </a>

      <a
        href="mailto:silventetomas@gmail.com"
        class="social-link"
        aria-label="Email"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="20" height="16" x="2" y="4" rx="2"></rect>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
        </svg>
        silventetomas@gmail.com
      </a>

      <span class="hidden sm:flex items-center gap-1.5 text-sm text-zinc-400 dark:text-zinc-500">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="13"
          height="13"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        Punta Alta, Argentina
      </span>
    </div>
  </div>
</section>

<style>
  .social-link {
    @apply flex items-center gap-2 text-sm text-zinc-500 dark:text-zinc-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors;
  }
</style>
