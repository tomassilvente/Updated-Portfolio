---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Tomás Silvente — Full Stack Developer",
  description = "Full Stack Developer & Systems Analyst based in Punta Alta, Argentina.",
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Tomás Silvente" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <!-- Prevent FOUC: initialize theme and lang before paint -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme") || "dark";
        const lang = localStorage.getItem("lang") || "en";
        if (theme === "light") {
          document.documentElement.classList.remove("dark");
        } else {
          document.documentElement.classList.add("dark");
        }
        document.documentElement.lang = lang;
      })();
    </script>
  </head>
  <body
    class="bg-white dark:bg-zinc-950 text-zinc-900 dark:text-zinc-100 antialiased font-sans"
  >
    <slot />
  </body>
</html>
